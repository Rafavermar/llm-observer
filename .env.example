OBSERVER_API_URL=http://observer-api:8080
OBSERVER_PUBLIC_API_URL=http://localhost:8080

# Optional provider keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_API_BASE=
AZURE_API_KEY=
AZURE_API_VERSION=2024-02-01
DATABRICKS_API_BASE=
DATABRICKS_API_KEY=

# LiteLLM
LITELLM_MASTER_KEY=sk-litellm-master-key
LITELLM_SALT_KEY=sk-litellm-salt-key
LITELLM_INTERNAL_URL=http://litellm-proxy:4000
LITELLM_PUBLIC_URL=http://localhost:4040
